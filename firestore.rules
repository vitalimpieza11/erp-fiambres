rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isBackend() {
      return request.auth.token.admin == true;
    }

    match /{document=**} {
      allow read: if isAuth();
      allow write: if isBackend();
    }
  }
}
