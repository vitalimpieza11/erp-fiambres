rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && getUserRole() == 'admin';
    }

    function isProduccion() {
      return signedIn() && (getUserRole() == 'admin' || getUserRole() == 'operario' || getUserRole() == 'produccion');
    }

    function isVentas() {
      return signedIn() && (getUserRole() == 'admin' || getUserRole() == 'ventas');
    }

    function isReadOnly() {
      return signedIn() && (getUserRole() == 'admin' || getUserRole() == 'operario' || getUserRole() == 'produccion' || getUserRole() == 'ventas' || getUserRole() == 'soloLectura');
    }

    // Reglas por colección
    
    // Configuración y Usuarios (Solo Admin)
    match /users/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /settings/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }
    match /financial_accounts/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }
    match /equivalences/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }

    // Producción y Stock
    match /products/{id} {
      allow read: if isReadOnly();
      allow write: if isProduccion();
    }
    match /recipes/{id} {
      allow read: if isReadOnly();
      allow write: if isProduccion();
    }
    match /packages/{id} {
      allow read: if isReadOnly();
      allow write: if isProduccion() || isVentas(); // Ventas modifica paquetes al vender
    }
    match /stock_movements/{id} {
      allow read: if isReadOnly();
      allow write: if isProduccion() || isVentas(); // Ventas deduce stock
    }

    // Ventas y Clientes
    match /customers/{id} {
      allow read: if isReadOnly();
      allow write: if isVentas();
    }
    match /orders/{id} {
      allow read: if isReadOnly();
      allow write: if isVentas() || isProduccion(); // Producción actualiza estado a PRODUCIDO
    }
    match /sales/{id} {
      allow read: if isReadOnly();
      allow write: if isVentas();
    }
    match /customer_movements/{id} {
      allow read: if isReadOnly();
      allow write: if isVentas();
    }
    match /caja_movements/{id} {
      allow read: if isReadOnly();
      allow write: if isVentas();
    }
    match /price_lists/{id} {
      allow read: if isReadOnly();
      allow write: if isVentas();
    }

    // Compras y Proveedores
    match /suppliers/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }
    match /purchases/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }
    match /supplier_movements/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }

    // Accionistas
    match /shareholders/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }
    match /shareholder_movements/{id} {
      allow read: if isReadOnly();
      allow write: if isAdmin();
    }
  }
}
